let ITERATION_NUMBER: uint8 = 16;

fun fibonacci(n: uint64): uint64 {
    if n <= 1 {
        return n;
    }

    return fibonacci(n - 1) + fibonacci(n - 2);
}

fun main() {
    for let i = 0; i < ITERATION_NUMBER; i = i + 1 {
        print("FIBONACCI ");
        println(fibonacci(i));
    }

    let i = 0;
    while i < 32 {
        print("WHILE");
        println(i);
        i = i + 1;
    }
}
