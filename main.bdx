let ITERATION_NUMBER: int64 = 16;

fun fibonacci(n: int64): int64 {
    if n <= 1 {
        return n;
    }

    return fibonacci(n - 1) + fibonacci(n - 2);
}

fun main() {
    for let i: int64 = 0; i < ITERATION_NUMBER; i = i + 1 {
        print("FIBONACCI ");
    }

    let i: int64 = 0;
    while i < 32 {
        print("WHILE");
        i = i + 1;
    }
}
